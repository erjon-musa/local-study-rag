# LM Studio (OpenAI-compatible local server)
LLM_BACKEND=lmstudio
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# Exact model IDs must match `GET /v1/models` from your running LM Studio instance.
LMSTUDIO_MODEL=<your-lmstudio-generation-model-id>
EMBEDDING_MODEL=<your-lmstudio-embedding-model-id>

# Path to your Obsidian-style study notes vault
VAULT_PATH=~/Documents/StudyVault

# Persistence directory for ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=100
